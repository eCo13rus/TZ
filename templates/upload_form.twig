{% extends 'base.twig' %}

{% block title %}Загрузка файла{% endblock %}

{% block body %}
        <form method="POST" enctype="multipart/form-data" class="mt-5" style="text-align: center;">
            <div class="mb-3" style="display: inline-block;">
                <input type="file" name="file" class="form-control">
            </div>
            <button type="submit" class="btn btn-primary" style="display: block; margin: auto;">Загрузить</button>
        
    {% if message is defined %}
        <p class="mt-3">{{ message }}</p>
    {% endif %}
    </form>
{% endblock %}


